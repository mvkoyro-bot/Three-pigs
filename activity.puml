@startuml
start

:Волк выбирает дом для атаки;

if (Какой дом?) then (Соломенный)
    :Дуть на соломенный дом;
    :Рассчитать урон (сопротивление 10%);
elseif (Деревянный)
    :Дуть на деревянный дом;
    :Рассчитать урон (сопротивление 30%);
else (Кирпичный)
    :Дуть на кирпичный дом;
    :Рассчитать урон (сопротивление 70%);
endif

:Проверить состояние дома;

if (Дом разрушен?) then (да)
    :Поросята убегают к другому дому;
    
    if (Это был кирпичный дом?) then (да)
        :Волк пытается пролезть в дымоход;
        if (Дымоход укреплён?) then (да)
            :Волк получает ожог;
            :Волк убегает;
            :Поросята спасены;
            stop
        else (нет)
            :Волк пролезает;
            :Волк ловит поросят;
            stop
        endif
    else (нет)
        :Волк продолжает атаку;
        :Переход к следующему дому;
    endif
else (нет)
    :Дом устоял;
    :Поросята остаются в доме;
endif

stop
@enduml
